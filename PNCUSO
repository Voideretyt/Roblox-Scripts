-- Core Logic
local inventory = {}
local bulkActive = false

BulkBtn.MouseButton1Click:Connect(function()
    bulkActive = not bulkActive
    BulkBtn.Text = bulkActive and "BULK: ON" or "BULK: OFF"
    BulkBtn.BackgroundColor3 = bulkActive and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(40, 40, 40)
end)

ClearBtn.MouseButton1Click:Connect(function()
    inventory = {}
    for _, v in pairs(InvScroll:GetChildren()) do if v:IsA("TextLabel") then v:Destroy() end end
end)

local regions = {
    {Name = "Kanto", Col = Color3.fromRGB(220, 60, 60), Pool = {C={"Pikachu", "Eevee"}, R={"Charizard"}, U={"Mewtwo"}, S={"Mew"}}},
    {Name = "Sinnoh", Col = Color3.fromRGB(100, 80, 200), Pool = {C={"Bidoof", "Piplup"}, R={"Lucario"}, U={"Dialga"}, S={"Arceus"}}},
    {Name = "Paldea", Col = Color3.fromRGB(180, 50, 255), Pool = {C={"Fuecoco", "Pawmi"}, R={"Tinkaton"}, U={"Miraidon"}, S={"Terapagos"}}}
}

local function addToInv(pokemon, rarity)
    inventory[pokemon] = (inventory[pokemon] or 0) + 1
    
    local item = Instance.new("TextLabel", InvScroll)
    item.Size = UDim2.new(1, 0, 0, 25)
    item.Text = string.format("[%s] %s (x%d)", rarity, pokemon, inventory[pokemon])
    item.BackgroundTransparency = 1
    item.TextColor3 = rarity == "SECRET" and Color3.new(1, 0.8, 0) or Color3.new(1,1,1)
    item.Font = Enum.Font.Gotham
    item.TextXAlignment = Enum.TextXAlignment.Left
end

local function roll(pool)
    local admin = (CodeBox.Text == "123")
    local rng = admin and math.random(1, 50) or math.random(1, 1000)
    if rng < 10 then return pool.S[math.random(1, #pool.S)], "SECRET"
    elseif rng < 80 then return pool.U[math.random(1, #pool.U)], "ULTRA"
    elseif rng < 300 then return pool.R[math.random(1, #pool.R)], "RARE"
    else return pool.C[math.random(1, #pool.C)], "Common" end
end

for _, data in pairs(regions) do
    local b = Instance.new("TextButton", PackScroll)
    b.Size = UDim2.new(1, 0, 0, 45)
    b.BackgroundColor3 = data.Col
    b.Text = data.Name:upper() .. " PACK"
    b.Font = Enum.Font.GothamBold
    b.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", b)
    
    b.MouseButton1Click:Connect(function()
        local limit = bulkActive and 10 or 1
        local opened = 0
        
        while opened < limit do
            local card, rar = roll(data.Pool)
            -- Duplicate Control: If bulk is on, only keep if we have less than 2
            if not bulkActive or (inventory[card] or 0) < 2 then
                addToInv(card, rar)
                opened = opened + 1
            end
            task.wait() -- Small wait to prevent crashing during heavy rolling
        end
    end)
end
