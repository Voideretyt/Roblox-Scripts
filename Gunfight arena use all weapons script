if game:GetService('CoreGui'):FindFirstChild('KingScript') then 
    game:GetService('CoreGui').KingScript:Destroy() 
end 

local repo = "https://raw.githubusercontent.com/deividcomsono/Obsidian/main/" 
local Library = loadstring(game:HttpGet(repo .. "Library.lua"))() 
local ThemeManager = loadstring(game:HttpGet(repo .. "addons/ThemeManager.lua"))() 
local SaveManager = loadstring(game:HttpGet(repo .. "addons/SaveManager.lua"))() 

local Window = Library:CreateWindow({ 
    Title = "Gunfight Arena | VTX Edition", 
    Center = true, 
    AutoShow = true, 
    TabGuiMargin = 5, 
    Footer = "MADE BY VTX", 
    ShowCustomCursor = true, 
}) 

local Tabs = { 
    Main = Window:AddTab("Combat", "gun"), 
    Camos = Window:AddTab("Customization", "paintbrush"), 
    Settings = Window:AddTab("Settings", "settings"), 
} 

-- Item Fetching 
local function GetItems(path) 
    local items = {} 
    for _, v in pairs(game:GetService('ReplicatedStorage')[path]:GetChildren()) do 
        table.insert(items, v.Name) 
    end 
    table.sort(items) 
    return items 
end 

local Weapons = GetItems("Weapons") 
local Camos = GetItems("Camos") 
local SelectedWeapon = Weapons[1] 
local SelectedCamo = Camos[1] 

-- WEAPONS SECTION
local WepBox = Tabs.Main:AddLeftGroupbox("Weapon Selector") 
WepBox:AddInput("WepSearch", { 
    Text = "Search Weapons", 
    Placeholder = "Search...", 
    Callback = function(Value) 
        local filtered = {} 
        for _, name in pairs(Weapons) do 
            if name:lower():find(Value:lower()) then table.insert(filtered, name) end 
        end 
        Library.Options.WeaponsDropdown:SetValues(filtered) 
    end 
}) 

WepBox:AddDropdown("WeaponsDropdown", { 
    Values = Weapons, 
    Default = 1, 
    Text = "Weapons List", 
    Callback = function(v) SelectedWeapon = v end, 
}) 

local EquipBox = Tabs.Main:AddRightGroupbox("Equip Actions") 
EquipBox:AddButton("Equip Primary", function() 
    game.Players.LocalPlayer:SetAttribute('Primary', SelectedWeapon) 
    Library:Notify("Set Primary: " .. SelectedWeapon) 
end) 

EquipBox:AddButton("Equip Secondary", function() 
    game.Players.LocalPlayer:SetAttribute('Secondary', SelectedWeapon) 
    Library:Notify("Set Secondary: " .. SelectedWeapon) 
end) 

-- CAMOS SECTION 
local CamoBox = Tabs.Camos:AddLeftGroupbox("Camo Selector") 
CamoBox:AddInput("CamoSearch", { 
    Text = "Search Camos", 
    Placeholder = "Search...", 
    Callback = function(Value) 
        local filtered = {} 
        for _, name in pairs(Camos) do 
            if name:lower():find(Value:lower()) then table.insert(filtered, name) end 
        end 
        Library.Options.CamosDropdown:SetValues(filtered) 
    end 
}) 

CamoBox:AddDropdown("CamosDropdown", { 
    Values = Camos, 
    Default = 1, 
    Text = "Camos List", 
    Callback = function(v) SelectedCamo = v end, 
}) 

local CamoActBox = Tabs.Camos:AddRightGroupbox("Camo Actions") 
CamoActBox:AddButton("Apply to Primary", function() 
    game.Players.LocalPlayer:SetAttribute('PrimaryCamo', SelectedCamo) 
    Library:Notify("Applied Camo to Primary") 
end) 

CamoActBox:AddButton("Apply to Secondary", function() 
    game.Players.LocalPlayer:SetAttribute('SecondaryCamo', SelectedCamo) 
    Library:Notify("Applied Camo to Secondary") 
end) 

-- SETTINGS 
local MenuGroup = Tabs.Settings:AddLeftGroupbox("Menu") 
MenuGroup:AddToggle("Cursor", { 
    Text = "Custom Cursor", 
    Default = true, 
    Callback = function(v) Library.ShowCustomCursor = v end 
}) 

-- TOGGLE LOGIC (RightShift Only)
game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.RightShift then
        Library:Toggle()
    end
end)

MenuGroup:AddButton("Unload Script", function() Library:Unload() end) 
Tabs.Settings:AddRightGroupbox("Credits"):AddLabel("VTX - n0t_v01t on Discord", true) 

ThemeManager:SetLibrary(Library) 
SaveManager:SetLibrary(Library) 
SaveManager:BuildConfigSection(Tabs.Settings) 
ThemeManager:ApplyToTab(Tabs.Settings) 

Library:Init()
